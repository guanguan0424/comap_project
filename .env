# 环境配置文件
# 基于您提供的登录信息进行配置

# 测试环境配置
TEST_ENV=test
RUN_LIVE_TESTS=1

# API测试配置
API_BASE_URL=http://localhost:8000
LOGIN_PATH=/api/auth/login

# UI测试配置
UI_BASE_URL=http://risemap-dev.savehmi.cn
LOGIN_URL=http://risemap-dev.savehmi.cn/base/customers

# 测试用户凭证
TEST_USERNAME=lp@savehmi.com
TEST_PASSWORD=123456

# 管理员凭证
ADMIN_USERNAME=admin@example.com
ADMIN_PASSWORD=admin123

# 其他测试用户（用于测试数据）
USER_PASSWORD=user123
RESTRICTED_PASSWORD=restricted123

# API测试超时配置
API_TIMEOUT=30

# 重试配置
API_RETRY_COUNT=3
API_RETRY_DELAY=1

# 浏览器配置
BROWSER=chromium
HEADLESS=false  # 为方便调试，设为可见模式
SLOW_MO=500  # 减慢操作便于观察

# 测试报告配置
GENERATE_HTML_REPORT=true
GENERATE_ALLURE_REPORT=false

# 并行测试配置
NUM_WORKERS=auto
RERUN_FAILURES=1
RERUN_DELAY=2